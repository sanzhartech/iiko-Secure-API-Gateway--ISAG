# ──────────────────────────────────────────────────────────────────────────────
#  ISAG — docker-compose environment template
#  Copy to .env (same dir as docker-compose.yml) and fill with REAL secrets.
#  NEVER commit the real .env. Generate strong random values, do not reuse.
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
# ──────────────────────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=isag_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=isag_db

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production

# ── iiko upstream ─────────────────────────────────────────────────────────────
IIKO_API_BASE_URL=https://api-ru.iiko.services
IIKO_API_KEY=CHANGE_ME_iiko_server_api_key

# ── Gateway client auth (MUST differ from IIKO_API_KEY) ───────────────────────
GATEWAY_CLIENT_SECRET=CHANGE_ME_long_random_secret

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACTIVE_KID=default

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated explicit origins. Do NOT use "*" with credentials.
CORS_ALLOWED_ORIGINS=http://localhost
CORS_ALLOW_CREDENTIALS=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP=100/minute
RATE_LIMIT_PER_USER=50/minute
RATE_LIMIT_AUTH_ENDPOINT=10/minute

# ── Admin seeding (optional — leave empty to skip default admin) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
