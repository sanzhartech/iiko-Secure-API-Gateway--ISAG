POSTGRES_USER=isag_admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=isag_db

DATABASE_URL=postgresql+asyncpg://isag_admin:change-me-postgres-password@db:5432/isag_db
REDIS_URL=redis://redis:6379/0

APP_ENV=production
IIKO_API_BASE_URL=https://api-ru.iiko.services
IIKO_API_KEY=replace-with-real-iiko-key
GATEWAY_CLIENT_SECRET=replace-with-strong-gateway-secret
JWT_ACTIVE_KID=default

CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_PER_IP=100/minute
RATE_LIMIT_PER_USER=50/minute
RATE_LIMIT_AUTH_ENDPOINT=10/minute
TRUSTED_PROXY_CIDRS=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password

BACKEND_BIND_HOST=127.0.0.1
BACKEND_PUBLISH_PORT=8000
FRONTEND_PUBLISH_PORT=80
PROMETHEUS_PUBLISH_PORT=9090
GRAFANA_PUBLISH_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=replace-with-strong-grafana-password
