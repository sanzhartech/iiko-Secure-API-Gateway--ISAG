{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "iiko Secure API Gateway — Security & Performance Dashboard",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (last 5m)",
      "description": "Total HTTP requests processed by the gateway in the last 5 minutes.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "sum(increase(isag_requests_total[5m]))",
          "instant": true,
          "legendFormat": "Requests"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Blocked (last 5m)",
      "description": "Security blocks triggered in the last 5 minutes.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 10 },
            { "color": "red", "value": 50 }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "sum(increase(isag_blocked_requests_total[5m]))",
          "instant": true,
          "legendFormat": "Blocked"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency (last 5m)",
      "description": "95th percentile end-to-end request latency.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "unit": "s",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1.0 }
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(isag_request_latency_seconds_bucket[5m])) by (le))",
          "instant": true,
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Block Rate %",
      "description": "Percentage of all requests that were blocked by any security stage.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 5 },
            { "color": "red", "value": 20 }
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "100 * sum(rate(isag_blocked_requests_total[5m])) / sum(rate(isag_requests_total[5m]))",
          "instant": true,
          "legendFormat": "Block Rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "description": "Requests per second over time, split by HTTP status code.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "sum(rate(isag_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Latency (Percentiles)",
      "description": "P50, P95 and P99 end-to-end request latency in seconds.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(isag_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(isag_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(isag_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Security Blocks Over Time",
      "description": "Rate of blocked requests per second grouped by block reason.",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rate_limit" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "invalid_token" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "replay_attack" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "forbidden" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "sum(rate(isag_blocked_requests_total[1m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Block Reasons Distribution",
      "description": "Breakdown of blocked requests by security stage reason.",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "isag-prometheus" },
          "expr": "sum(increase(isag_blocked_requests_total[1h])) by (reason)",
          "legendFormat": "{{reason}}",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["isag", "security", "gateway"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ISAG — Security & Performance",
  "uid": "isag-main-dashboard",
  "version": 1
}
